{
  "name": "@agent-bridge/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "LOCAGENS_SETTINGS_PATH=../../.locagens-dev/settings.json LOCAGENS_DB_PATH=../../.locagens-dev/locagens.db tsx watch src/server.ts",
    "build": "tsc",
    "build:bundle": "esbuild src/server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.bundle.cjs",
    "test": "NODE_ENV=test node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@agent-bridge/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}

{
  "name": "agent-bridge",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev:shared": "pnpm --filter @agent-bridge/shared dev",
    "dev:api": "pnpm --filter @agent-bridge/api dev",
    "dev:web": "pnpm --filter @agent-bridge/web dev",
    "dev": "pnpm --recursive --parallel dev",
    "build": "pnpm --recursive build",
    "clean": "pnpm --recursive exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
